# Copy this file to .env for local Docker Compose runs.
# Keep real API keys and command tokens out of git.

# Host ports
CHATBOT_PORT=8088
QDRANT_PORT=6333
QDRANT_URL=http://playground-qdrant:6333

# Optional provider defaults
CHATBOT_DEFAULT_PROVIDER=openai
CHATBOT_DEFAULT_MODEL=gpt-4.1-mini

# Optional VIP token for executing "Simon says" commands.
# Normal questions do not need this token.
CHATBOT_COMMAND_TOKEN=change-me-to-a-long-random-secret

# Local Ollama endpoints
LOCAL_LLM_URL=http://playground-ollama:11434/api/chat
OLLAMA_EMBED_URL=http://playground-ollama:11434/api/embed

# Remote LLM and embedding providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional external REST source example
COMPANY_API_URL=http://host.docker.internal:8001/health

# Optional playground GraphQL API settings for "Simon says get/add/delete employee"
API_URL=http://host.docker.internal:8000/graphql
FASTAPI_BASIC_AUTH_USERNAME=admin
FASTAPI_BASIC_AUTH_PASSWORD=password
