# Central host-port mapping for the playground stack.
# Update values here to keep all services in sync.

VAULT_PORT = 8200
API_PORT = 8000
GITEA_HTTP_PORT = 3000
GITEA_SSH_PORT = 2222
GITLAB_HTTP_PORT = 8929
GITLAB_SSH_PORT = 2224
NEXUS_HTTP_PORT = 8083
PROD_HTTP_PORT = 8081
DEV_HTTP_PORT = 8082
NGINX_HTTPS_PORT = 8443
OLLAMA_PORT = 11435
CHATBOT_PORT = 8088

# Shared URLs derived from the centralized ports.
VAULT_ADDR = http://127.0.0.1:$(VAULT_PORT)
API_URL = http://127.0.0.1:$(API_PORT)
GITEA_ROOT_URL = http://localhost:$(GITEA_HTTP_PORT)/
GITLAB_EXTERNAL_URL = http://localhost:$(GITLAB_HTTP_PORT)
NGINX_URL = https://localhost:$(NGINX_HTTPS_PORT)
OLLAMA_URL = http://127.0.0.1:$(OLLAMA_PORT)
CHATBOT_URL = http://127.0.0.1:$(CHATBOT_PORT)
